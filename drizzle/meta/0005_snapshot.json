        "campaigns_target_daily_emails_check": {
          "name": "campaigns_target_daily_emails_check",
          "value": "\"campaigns\".\"target_daily_emails\" between 1 and 200"
        },
        "campaigns_niche_recommendation_ids_json_array_check": {
          "name": "campaigns_niche_recommendation_ids_json_array_check",
          "value": "jsonb_typeof(\"campaigns\".\"niche_recommendation_ids\") = 'array'"
        },
        "campaigns_approved_niche_ids_json_array_check": {
          "name": "campaigns_approved_niche_ids_json_array_check",
          "value": "jsonb_typeof(\"campaigns\".\"approved_niche_ids\") = 'array'"
        },
        "campaigns_review_states_recommendations_check": {
          "name": "campaigns_review_states_recommendations_check",
          "value": "case when \"campaigns\".\"state\" in ('niche_review', 'discovery_ready') then case when jsonb_typeof(\"campaigns\".\"niche_recommendation_ids\") = 'array' then jsonb_array_length(\"campaigns\".\"niche_recommendation_ids\") > 0 else false end else true end"
        },
        "campaigns_discovery_ready_approved_check": {
          "name": "campaigns_discovery_ready_approved_check",
          "value": "case when \"campaigns\".\"state\" = 'discovery_ready' then case when jsonb_typeof(\"campaigns\".\"approved_niche_ids\") = 'array' then jsonb_array_length(\"campaigns\".\"approved_niche_ids\") > 0 else false end else true end"
        },
        "campaigns_version_positive_check": {
          "name": "campaigns_version_positive_check",
          "value": "\"campaigns\".\"version\" >= 1"
        }
      },
